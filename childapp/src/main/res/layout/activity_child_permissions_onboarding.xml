<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Нужно настроить разрешения"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="@android:color/black" />

        <TextView
            android:id="@+id/tvDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Это нужно один раз после регистрации, чтобы работали защита контента, блокировка сайтов и контроль экранного времени."
            android:textSize="14sp"
            android:textColor="#333333" />

        <!-- BLUR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:padding="14dp"
            android:orientation="vertical"
            android:background="#F2F2F2">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1) Защита контента (Blur)"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@android:color/black" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Нужно разрешение «поверх других приложений», чтобы обезопасить тебя от нежелательного контента на экране."
                android:textSize="14sp"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/tvBlurStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Статус: —"
                android:textSize="14sp"
                android:textColor="#333333" />

            <Button
                android:id="@+id/btnBlurSetup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Настроить Blur" />
        </LinearLayout>

        <!-- BLOCKER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:padding="14dp"
            android:orientation="vertical"
            android:background="#F2F2F2">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2) Блокировка сайтов"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@android:color/black" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Нужно включить сервис в специальных возможностях (Accessibility), чтобы блокер мог защитить тебя от опасных сайтов в браузере."
                android:textSize="14sp"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/tvBlockerStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Статус: —"
                android:textSize="14sp"
                android:textColor="#333333" />

            <Button
                android:id="@+id/btnBlockerSetup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Настроить блокер" />
        </LinearLayout>

        <!-- TIMEGUARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:padding="14dp"
            android:orientation="vertical"
            android:background="#F2F2F2">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3) Контроль экранного времени"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@android:color/black" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Нужно включить сервис Accessibility, чтобы родитель мог знать, сколько ты проводишь времени в телефоне."
                android:textSize="14sp"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/tvTimeGuardStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Статус: —"
                android:textSize="14sp"
                android:textColor="#333333" />

            <Button
                android:id="@+id/btnTimeGuardSetup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Настроить экранное время" />
        </LinearLayout>

        <Button
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Продолжить"
            android:enabled="false" />

    </LinearLayout>
</ScrollView>
