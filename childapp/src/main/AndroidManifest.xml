<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <!-- обязательно для foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>

    <!-- обязательно на Android 14+ если используешь foregroundServiceType="location" -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION"/>

    <!-- Android 13+ иначе уведомление может быть запрещено (лучше запросить) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Для Android 10+ если хочешь трекать в фоне (а у тебя сервис) -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <application
        android:theme="@style/Theme.ChildApp"
        android:allowBackup="true"
        android:label="ChildApp"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"

        tools:replace="android:usesCleartextTraffic,android:networkSecurityConfig">

        <activity
            android:name=".CodeActivity"
            android:exported="true" />
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>

            </intent-filter>
        </activity>
        <activity
            android:name=".ChildHomeActivity"
            android:exported="false" />
        <activity
            android:name="com.example.overlaydetector.MainActivity"
            android:exported="true" />
        <activity
            android:name=".GpsPermissionActivity" />

        <service
            android:name=".LocationUploadService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <service
            android:name="com.example.timeguard.service.AppTimeGuardService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/time_guard_accessibility" />
        </service>

        <activity
            android:name="com.example.timeguard.BlockedActivity"
            android:exported="false" />


        <activity
            android:name=".ChildScreenTimeStatusActivity"
            android:exported="false" />


        <activity android:name=".ChildSettingsActivity" />

        <activity
            android:name=".ChildParentMessagesActivity"
            android:exported="false" />

        <activity android:name=".ChildPermissionsOnboardingActivity" />




    </application>

</manifest>
